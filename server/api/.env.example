# Runtime
NODE_ENV=production
PORT=3001
NETWORK=mainnet

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=zcash_explorer_mainnet
DB_USER=zcash_user
DB_PASSWORD=replace_me

# Zebra JSON-RPC and indexer stream
ZEBRA_RPC_URL=http://127.0.0.1:8232
ZEBRA_RPC_COOKIE_FILE=/root/.cache/zebra/.cookie
ZEBRA_GRPC_URL=127.0.0.1:8230

# API protection and upstream integrations
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
SERVICE_API_KEYS=replace_me
NEAR_INTENTS_API_KEY=replace_me

# Shared list-response cache. Opt in only when Redis is private and persistent.
API_LIST_CACHE_ENABLED=0
API_CACHE_NAMESPACE=mainnet
API_LIST_CACHE_MAX_ENTRIES=1000
API_LIST_CACHE_REDIS_TIMEOUT_MS=50

# Optional operations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
