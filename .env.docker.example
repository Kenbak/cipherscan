# Image pins - set any to a specific tag, digest, or commit-tagged image.
ZEBRA_IMAGE=zfnd/zebra:2.4.0
LIGHTWALLETD_IMAGE=electriccoinco/lightwalletd:v0.4.17
POSTGRES_IMAGE=postgres:16-bookworm
REDIS_IMAGE=redis:7-bookworm
# Locally built images (override to pull a prebuilt commit image instead):
WEB_IMAGE=cipherscan-web:local
API_IMAGE=cipherscan-api:local
# Build args for the locally built images:
NODE_IMAGE=node:22.14.0-bookworm-slim
GIT_COMMIT=unknown

# Network: Mainnet or Testnet
ZEBRA_NETWORK=Mainnet
NEXT_PUBLIC_NETWORK=mainnet

# Database credentials
DB_NAME=zcash_explorer
DB_USER=zcash_user
DB_PASSWORD=changeme

# Public-facing URLs (as reached from the browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_LIGHTWALLETD_HOST=lightwalletd
CORS_ORIGINS=http://localhost:3000
WEB_PORT=3000

# --- Testnet mining (Zebra internal miner) - see docker-compose.mining.yml ---
# Testnet ONLY. Set this to a testnet transparent (tm...) address to receive
# the coinbase. Required when using the mining overlay.
ZEBRA_MINER_ADDRESS=tmUqQn2hFWTRBNSypuMDahHww6bZLr3BrN2
# Zebra source ref to build the mining image from (tag/branch/commit).
ZEBRA_REF=v2.4.0
